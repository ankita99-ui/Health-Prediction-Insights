# Copy this file to ".env" (same folder) and adjust the values.
# Never commit the real .env file - it is excluded by .gitignore.

# --- Option A: Microsoft SQL Server (default) ------------------------------
# Your instance name may differ! Common values:
#   localhost\SQLEXPRESS   (SQL Server Express default)
#   localhost\MSSQL        (named instance)
#   localhost              (default unnamed instance)
# Find yours in SSMS: it's the "Server name" you connect with.
MSSQL_SERVER=localhost\MSSQL
MSSQL_DATABASE=HealthDB
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# --- Option B: no SQL Server? Use SQLite instead ---------------------------
# Uncomment the next line and the app runs with a simple file database,
# no installation needed (ignores the MSSQL_* settings above):
# DATABASE_URL=sqlite:///./health_app.db

# --- Frontend: where the FastAPI backend is running ------------------------
API_URL=http://127.0.0.1:8000
